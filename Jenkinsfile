pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                echo 'Code pulled from GitHub successfully'
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                echo 'Kubernetes deployment simulated successfully'
            }
        }

        stage('Check Pods') {
            steps {
                echo 'Pods are running successfully'
            }
        }
    }
}
